# Ambiente virtual
.venv/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Jupyter checkpoints
.ipynb_checkpoints/

# Dados processados — gerados por código, nunca versionados
dados/processed/*
!dados/processed/.gitkeep

# Dados brutos reais — pesados ou com restrições de redistribuição (SUSEP, ANS, DENATRAN)
dados/raw/*.csv
dados/raw/*.xlsx
dados/raw/*.parquet
dados/raw/*.zip
dados/raw/*.gz

# Outputs gerados pelos notebooks e scripts
*.png
*.jpg
*.jpeg

# Sistema operacional
.DS_Store
Thumbs.db
